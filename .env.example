# =============================================================================
# financial-intelligence-platform — environment variables
#
# Copy this file to .env and fill in the values before starting the app.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# dev | staging | prod
# Controls log format (console vs JSON), docs visibility (/docs hidden in prod)
ENVIRONMENT=dev

# Enable SQLAlchemy query echo and verbose logging
DEBUG=false

# Displayed in OpenAPI docs and log lines
APP_NAME=financial-intelligence-platform
APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Database
# Uses postgresql+asyncpg:// for the async app.
# Alembic migrations use the sync URL (psycopg2), derived automatically.
#
# Docker Compose: replace "localhost" with the service name "postgres".
# Example: postgresql+asyncpg://postgres:postgres@postgres:5432/finplatform
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finplatform

# -----------------------------------------------------------------------------
# Security
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Minimum length: 32 characters.
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production-use-at-least-32-chars

# JWT access token lifetime in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT signing algorithm — HS256 is the default; RS256 is available for
# asymmetric signing if you supply RSA key material.
ALGORITHM=HS256

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------

# Alpha Vantage — used for supplemental market data (optional)
# Sign up at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# -----------------------------------------------------------------------------
# CORS
# JSON list of allowed origins for browser requests.
# In production, replace with your actual frontend URL(s).
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
